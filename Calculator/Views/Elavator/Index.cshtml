@model Calculator.Models.User

<head>
    <meta charset="utf-8" />
    <title>ماشین حساب</title>
    <style>
   input[type="text"], input[type="email"], input[type="password"], input[type="number"] {
    width: 14%;
/*    padding: 8px 10px;
*/    margin: 8px 0;
    box-sizing: border-box;
    border: 2px solid #ccc;
    border-radius: 4px;
}
button {
    background-color: hsla(50, 33%, 25%, .75);
    color: white;
    margin: 8px 0;
    border: none;
    border-radius: 4px;
    cursor: pointer;
}

button:hover {
    background-color: #45a049;
}
form {
    border: 3px solid #f1f1f1;
    padding: 20px;
    border-radius: 5px;
}
input[type=text] {
  transition: width 0.5s ease-in-out;
}

input[type=number]:focus {
  width: 17%;
}
select {
  width: 14%;
  /*padding: 12px 20px;*/
  border: none;
  border-radius: 4px;
  background-color: #f1f1f1;
}
input[type=button], input[type=submit], input[type=reset] {
  background-color: cyan;
  border: none;
  color: gray;
  padding: 16px 32px;
  text-decoration: none;
  margin: 4px 2px;
  box-sizing: border-box;
  cursor: pointer;
}

    </style>
  </head>
  <body>
<form asp-action="Index" method="post" dir="rtl" >
