         <label>ضریب در طول مدت</label>
            <select id =NumberDropdownn asp-for="zaribe" >
            <script>
   dropdown = document.getElementById('NumberDropdownn');
  for (let i = 1; i <= 50; i++) {
     option = document.createElement('option');
      //option.value = i;

    if (i == 2) {
        option.value = 0.15;
    } else if (i == 3) {
        option.value = 0.25;
    } else if (i >= 4) {
        option.value = 0.25 + (i - 3) * 0.05;
    } else {
        option.value = 1; 
    }
    
    option.textContent = i;
    dropdown.appendChild(option);
  }
</script>
</select>
        <div>
